# Real receipt scans use local OCR by default and do not require a key.
RECEIPT_SCAN_ENGINE=offline
# Optional: set RECEIPT_SCAN_ENGINE=openai to use this future-facing path.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
# Global UTC-day circuit breaker; set 0 to disable Live calls.
OPENAI_DAILY_CALL_LIMIT=3
DEMO_TOKEN=replace-with-a-long-random-token
ADMIN_TOKEN=replace-with-a-different-long-random-token
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
# Optional; defaults to server/freshledger.db.
FRESHLEDGER_DB_PATH=
# Load the three bundled judge fixtures when the receipts table is empty, unless
# the user explicitly chose Reset all data (that choice persists in SQLite).
AUTO_SEED_DEMO_DATA=true
